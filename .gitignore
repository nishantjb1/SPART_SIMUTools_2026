# ============================================================
# SPART — .gitignore
# ============================================================

# --- Proprietary dataset files (MUST NOT be committed) ---
vehicle_tracks_*.csv

# --- Python artifacts ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
.eggs/
.pytest_cache/

# --- Experiment result files (large; excludes everything except synthetic demo) ---
results/fidelity/
results/ablation/
results/benchmark/
results/grid_crossover/
# Keep results/synthetic_demo/ -- it's the reproducible no-dataset demo output

# --- Old / confidential files (read-only reference material, NOT for release) ---
SPART_Old.ipynb
SPART_ITSC_Old.pdf
SPART_ITSC_old.tex
SPART_Handoff_ClaudeCode.md.pdf
SPART_Old_Audit_Report.md.pdf
handoff_extracted.txt

# --- LaTeX build artifacts (Paper/) ---
Paper/*.aux
Paper/*.log
Paper/*.bbl
Paper/*.blg
Paper/*.out
Paper/*.synctex.gz
Paper/SPART_SIMUTools2026.pdf
Paper/SPART_ITSC_Old.pdf

# --- The wrong old figure (replace with results/benchmark/ version) ---
Paper/fps_vs_vehicles_comparison.png

# --- IDE / OS ---
.vscode/settings.json
.vscode/
.claude/
memory/
*.DS_Store
Thumbs.db

# --- Jupyter ---
*.ipynb_checkpoints/

/Paper/
